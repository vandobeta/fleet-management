<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A1A"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TRACKER SMS"
            android:textColor="#00FF88"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tracker_number_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="+000000000000"
            android:textColor="#888888"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- Status Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A1A"
        android:layout_margin="12dp"
        android:padding="16dp">

        <!-- Connection Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:id="@+id/status_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="#FF4444"
                android:layout_gravity="center_vertical"/>

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Not Connected"
                android:textColor="#00FF88"
                android:textSize="14sp"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <!-- Last Update -->
        <TextView
            android:id="@+id/last_update_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Last update: --"
            android:textColor="#666666"
            android:textSize="11sp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Get Location -->
        <Button
            android:id="@+id/btn_get_location"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📍 GET LOCATION"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_bg"
            android:layout_marginBottom="8dp"/>

        <!-- Get Status -->
        <Button
            android:id="@+id/btn_get_status"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="📊 GET STATUS"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_bg_purple"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>

    <!-- Engine Control -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ENGINE CONTROL"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:paddingStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btn_engine_on"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="🔑 ENGINE ON"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_bg_green"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_engine_off"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="⛔ ENGINE OFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_bg_red"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

    <!-- Navigate Button -->
    <Button
        android:id="@+id/btn_navigate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🧭 NAVIGATE TO CAR"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_bg_blue"
        android:layout_margin="12dp"/>

    <!-- Quick Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btn_commands"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Commands"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_small_bg"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_map"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="🗺️ Map"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_small_bg"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="⚙️"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_small_bg"
            android:layout_marginStart="4dp"/>

    </LinearLayout>

</LinearLayout>